# --- Node.js Parent GitIgnore ---

# Dependency directories (Matches node_modules in any subfolder)
**/node_modules/
**/jspm_packages/
**/.pnpm-store

# Logs
**/logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/lerna-debug.log*

# Runtime data and Diagnostics
**/report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
**/pids
**/*.pid
**/*.seed
**/*.pid.lock

# Build and Output directories
**/dist/
**/out/
**/.next/
**/.nuxt/
**/.output/
**/.svelte-kit/
**/.vuepress/dist/
**/.temp/
**/.serverless/
**/build/Release/

# Tooling Caches
**/.cache/
**/.parcel-cache/
**/.eslintcache/
**/.stylelintcache/
**/.nyc_output/
**/.grunt/
**/.docusaurus/
**/.fusebox/
**/.firebase/
**/*.tsbuildinfo

# Environment files
**/.env
**/.env.*
!**/.env.example

# OS files & REPL
**/.node_repl_history
**/*.tgz
**/.yarn-integrity
**/.tern-port
**/.vscode-test

# Vite/Vitepress specific
**/.vite/
**/.vitepress/dist/
**/.vitepress/cache/
**/vite.config.js.timestamp-*
**/vite.config.ts.timestamp-*

# Yarn v3 (Berry)
**/.pnp.*
**/.yarn/*
!**/.yarn/patches
!**/.yarn/plugins
!**/.yarn/releases
!**/.yarn/sdks
!**/.yarn/versions